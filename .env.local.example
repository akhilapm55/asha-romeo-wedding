# ─────────────────────────────────────────────────────────────
#  Asha & Romeo — environment variables
#  Copy this file to `.env.local` and fill in the values.
#  NONE of these are exposed to the browser (no NEXT_PUBLIC_ prefix).
# ─────────────────────────────────────────────────────────────

# Google Apps Script Web App URL that appends RSVP rows to the Sheet.
# Deploy the script in /apps-script/Code.gs as a Web App ("Anyone").
APPS_SCRIPT_RSVP_URL=

# Shared access key that gates the private /guest-dashboard route.
# Visit: /guest-dashboard?key=YOUR_KEY_HERE
DASHBOARD_ACCESS_KEY=change-me-to-a-long-random-string
